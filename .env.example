APP_NAME="Opes Books"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────
# Dev: SQLite (default). Prod: switch to mysql and fill values below.
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=opesbooks
# DB_USERNAME=opesbooks
# DB_PASSWORD=

# ── Session / Cache ───────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
CACHE_STORE=database
QUEUE_CONNECTION=database

# ── Filesystem ────────────────────────────────────────────────────────────────
# IMPORTANT: must be "public" so company logos are served via /storage URLs.
# Run `php artisan storage:link` once after deploy.
FILESYSTEM_DISK=public

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@opesbooks.cm"
MAIL_FROM_NAME="${APP_NAME}"

# ── DGI Fiscalis / SIGIT (Cameroun e-invoicing 2026) ─────────────────────────
# Obtain credentials from: https://teledeclaration-dgi.cm
DGI_ENDPOINT=https://teledeclaration-dgi.cm/api/invoices
DGI_API_KEY=
DGI_TIMEOUT=15

# ── Payment Aggregator (Maviance / Bizao / CinetPay) ─────────────────────────
# Used for subscription billing STK push.
PAYMENT_AGGREGATOR_ENDPOINT=
PAYMENT_AGGREGATOR_API_KEY=
PAYMENT_AGGREGATOR_MERCHANT_ID=

# ── MTN Mobile Money (direct integration — optional if using aggregator) ──────
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_ENVIRONMENT=sandbox

# ── Orange Money (direct integration — optional if using aggregator) ──────────
ORANGE_MONEY_BASE_URL=https://api.orange.com/orange-money-webpay/cm/v1
ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=
ORANGE_MONEY_MERCHANT_KEY=

# ── AWS S3 (optional — only if using S3 for file storage instead of local) ───
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
