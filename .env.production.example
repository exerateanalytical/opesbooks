# ── OPESBooks — Production (.env) ────────────────────────────────────────────
# Copy to ".env" on the server, then: php artisan key:generate
APP_NAME="Opes Books"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://opesbooks.cm        # ← your real domain (or https://app.opesbooks.cm)
APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR
APP_MAINTENANCE_DRIVER=file

# ── Database (cPanel MySQL) ──────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cpaneluser_opesbooks    # ← cPanel-created DB name
DB_USERNAME=cpaneluser_opesbk       # ← cPanel-created DB user
DB_PASSWORD=                        # ← that user's password

# ── Session / Cache / Queue (all DB-backed — no Redis needed) ────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
CACHE_STORE=database
QUEUE_CONNECTION=database

# ── Filesystem (MUST be public for logo uploads/URLs) ────────────────────────
FILESYSTEM_DISK=public

# ── Mail (cPanel email account or transactional SMTP) ────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mail.opesbooks.cm
MAIL_PORT=465
MAIL_USERNAME=noreply@opesbooks.cm
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="noreply@opesbooks.cm"
MAIL_FROM_NAME="${APP_NAME}"

# ── DGI Fiscalis / SIGIT ─────────────────────────────────────────────────────
DGI_ENDPOINT=https://teledeclaration-dgi.cm/api/invoices
DGI_API_KEY=
DGI_TIMEOUT=15

# ── AI (optional — leave blank to degrade to "AI unavailable") ───────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
# Ollama is NOT available on shared hosting — leave disabled.

# ── Payments (sandbox until real merchant creds are issued) ──────────────────
PAYMENT_ENV=sandbox
ORANGE_MONEY_MERCHANT_KEY=
ORANGE_MONEY_MERCHANT_SECRET=
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_TARGET_ENV=sandbox

LOG_CHANNEL=stack
LOG_LEVEL=error
